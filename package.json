{
  "name": "foto-manager-app",
  "version": "1.0.1",
  "description": "Gestão de fotos de produtos — Eita Casa Perfeita",
  "author": "Eita Casa Perfeita",
  "main": "src/main.js",
  "scripts": {
    "start": "node run-electron.js",
    "dev": "concurrently \"npm run vite\" \"wait-on http://localhost:5200 && node run-electron.js\"",
    "vite": "vite",
    "build": "vite build",
    "package": "npm run build && electron-forge package",
    "make": "npm run build && electron-forge make",
    "publish-release": "node publish-release.js"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "electron-squirrel-startup": "^1.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.23.1"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.4.0",
    "@electron-forge/maker-squirrel": "^7.4.0",
    "@electron-forge/maker-zip": "^7.4.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "electron": "^31.7.7",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "vite": "^5.3.1",
    "vite-plugin-electron": "^0.28.7",
    "wait-on": "^7.2.0"
  },
  "config": {
    "forge": {
      "packagerConfig": {
        "name": "Foto Manager",
        "icon": "./assets/icon",
        "appVersion": "1.0.1",
        "ignore": [
          "^/nul$",
          "^/assets/nul$",
          "/nul$"
        ]
      },
      "makers": [
        {
          "name": "@electron-forge/maker-squirrel",
          "platforms": [
            "win32"
          ],
          "config": {
            "name": "FotoManager",
            "authors": "Eita Casa Perfeita",
            "owners": "Eita Casa Perfeita",
            "description": "Gestão de fotos de produtos — Eita Casa Perfeita",
            "setupIcon": "./assets/icon.ico",
            "setupExe": "FotoManager-Setup.exe",
            "noMsi": true
          }
        },
        {
          "name": "@electron-forge/maker-zip",
          "platforms": [
            "darwin"
          ]
        }
      ]
    }
  }
}
